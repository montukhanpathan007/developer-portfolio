# Site URL used for SEO metadata, sitemap and robots (set to your Vercel domain).
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app

# EmailJS (https://www.emailjs.com — free tier works).
# Create a service + template with variables: name, email, subject, message.
# Until these are set, the contact form falls back to opening the visitor's mail client.
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=
